    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output[0].content[0].text;\n\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  return [{\n    json: {\n      ticket_id: $('Edit Fields').first().json.ticket_id,\n      source: $('Edit Fields').first().json.source,\n      raw_message: $('Edit Fields').first().json.raw_message,\n      received_at: $('Edit Fields').first().json.received_at,\n      parse_failed: true,\n      escalation_flag: true,\n      escalation_reason: \"JSON parse failure on LLM output\"\n    }\n  }];\n}\n\nconst required = [\"category\", \"priority\", \"confidence\", \"core_issue\", \"entities\", \"urgency_signal\", \"summary\"];\nconst missing = required.filter(f => parsed[f] === undefined);\n\nif (missing.length > 0) {\n  return [{\n    json: {\n      ticket_id: $('Edit Fields').first().json.ticket_id,\n      source: $('Edit Fields').first().json.source,\n      raw_message: $('Edit Fields').first().json.raw_message,\n      received_at: $('Edit Fields').first().json.received_at,\n      parse_failed: true,\n      escalation_flag: true,\n      escalation_reason: `Missing fields: ${missing.join(\", \")}`\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ticket_id: $('Edit Fields').first().json.ticket_id,\n    source: $('Edit Fields').first().json.source,\n    raw_message: $('Edit Fields').first().json.raw_message,\n    received_at: $('Edit Fields').first().json.received_at,\n    parse_failed: false,\n    ...parsed\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        608,
        -128
      ],
      "id": "38a2838d-532b-453e-b644-9245b2f5738a",
      "name": " Code (Parse + Validate)"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nif (item.parse_failed) {\n  return [{ json: item }];\n}\n\nconst message = (item.raw_message ?? \"\").toLowerCase();\nconst amountUsd = item.entities?.amount_usd ?? 0;\n\nlet escalation_flag = false;\nlet escalation_reason = null;\n\nif (item.confidence < 0.7) {\n  escalation_flag = true;\n  escalation_reason = `Low confidence: ${item.confidence}`;\n}\n\nif (/outage|down for all|down for everyone|multiple users affected|multiple users/i.test(message)) {\n  escalation_flag = true;\n  escalation_reason = escalation_reason\n    ? escalation_reason + \" + keyword match\"\n    : \"Keyword match: outage/multiple users\";\n}\n\nif (item.category === \"Billing Issue\" && amountUsd > 500) {\n  escalation_flag = true;\n  escalation_reason = escalation_reason\n    ? escalation_reason + \" + billing threshold\"\n    : `Billing amount $${amountUsd} exceeds threshold`;\n}\n\nreturn [{\n  json: {\n    ...item,\n    escalation_flag,\n    escalation_reason\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        -128
      ],
      "id": "414985a3-aabe-46c4-9455-267d68a7362f",
      "name": "Code (Escalation Rules)"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\n\nconst routingMap = {\n  \"Bug Report\": \"Engineering\",\n  \"Feature Request\": \"Product\",\n  \"Billing Issue\": \"Billing\",\n  \"Technical Question\": \"IT/Security\",\n  \"Incident/Outage\": \"Engineering\"\n};\n\nconst routing_destination = item.escalation_flag\n  ? \"Escalation\"\n  : (routingMap[item.category] ?? \"Escalation\");\n\nreturn [{\n  json: {\n    ...item,\n    routing_destination\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
