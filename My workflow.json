      ],
      "id": "80c044f3-3f63-48dc-910d-f082c62d8c86",
      "name": "Message a model",
      "credentials": {
        "openAiApi": {
          "id": "ioV6YXsRb6zLC6yJ",
          "name": "OpenAi account"
        }
